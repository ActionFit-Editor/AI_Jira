    \uC54A\uC544\uB3C4 \uBC94\uC704\uC640 \uC704\uD5D8\uC744 \uD655\uC778\uD560 \uC218
    \uC788\uC2B5\uB2C8\uB2E4.\n- \uC2B9\uC778 \uC804\uC5D0 Jira \uC800\uC7A5\uC6A9
    \uD63C\uD569 \uC5B8\uC5B4 \uC6D0\uBB38\uC744 \uBA3C\uC800 \uD655\uC815\uD558\uACE0,
    \uC2B9\uC778 \uD6C4\uC5D0\uB294 \uD574\uB2F9 \uC6D0\uBB38\uC744 \uADF8\uB300\uB85C
    \uC0AC\uC6A9\uD574 \uD55C\uAE00 \uD45C\uC2DC\uBCF8\uC744 \uB2E4\uC2DC \uC601\uBB38\uC73C\uB85C
    \uBC88\uC5ED\uD558\uB294 \uC624\uB958\uB97C \uBC29\uC9C0\uD569\uB2C8\uB2E4.\n-
    \uACC4\uD68D \uC218\uC815\uC774\uB098 \uB300\uD654 \uC911\uB2E8\uC73C\uB85C \uC6D0\uBB38
    \uC0C1\uD0DC\uAC00 \uBD88\uD655\uC2E4\uD574\uC9C0\uBA74 \uD55C\uAE00 \uD45C\uC2DC\uBCF8\uACFC
    \uC6D0\uBB38\uC744 \uD568\uAED8 \uB2E4\uC2DC \uC0DD\uC131\uD558\uACE0 \uC7AC\uC2B9\uC778\uC744
    \uC694\uAD6C\uD574 \uC624\uB798\uB41C \uC2B9\uC778\uC774 \uC7AC\uC0AC\uC6A9\uB418\uC9C0
